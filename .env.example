# BillForge — Required Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local to git.

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Set to your Railway public URL in production (e.g. https://yourapp.up.railway.app)
# Leave as http://localhost:3000 for local development
NEXTAUTH_URL="http://localhost:3000"

# ─── Database ──────────────────────────────────────────────────────────────────
# Your PostgreSQL connection string (Railway provides this automatically if you
# add a PostgreSQL service and reference it: ${{Postgres.DATABASE_URL}})
DATABASE_URL="postgresql://user:password@host:port/database"
