# BillForge — Required Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local to git.

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Set to your Vercel public URL in production (e.g. https://your-app.vercel.app)
# Leave as http://localhost:3000 for local development
NEXTAUTH_URL="http://localhost:3000"

# ─── Database ──────────────────────────────────────────────────────────────────
# Your PostgreSQL connection string (e.g. from Vercel Postgres, Neon, or Supabase)
DATABASE_URL="postgresql://user:password@host:port/database"

# ─── Google OAuth (optional) ───────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI:
#    - Local: http://localhost:3000/api/auth/callback/google
#    - Production: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="373086185544-ernul5bd86hpogfies166rb2butjnmhf.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"

# ─── Upstash Redis (optional) ─────────────────────────────────────────────────
# Used for rate limiting and caching. App works fine without it.
# Get free tier at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
